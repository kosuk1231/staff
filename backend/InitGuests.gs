// ── 좌석세팅 초기화 ──────────────────────────────────────
function initSeatSheet(ss) {
  var sheet = ss.getSheetByName('02_좌석세팅');
  if (!sheet) {
    sheet = ss.insertSheet('02_좌석세팅');
  }
  sheet.clear();
  
  // 헤더
  var headers = ['좌석번호','열구분','순번','상태','내빈ID','이름','소속','직함','최종변경시간'];
  sheet.getRange(1, 1, 1, headers.length).setValues([headers]);
  sheet.getRange(1, 1, 1, headers.length).setFontWeight('bold');
  sheet.getRange(1, 1, 1, headers.length).setBackground('#f3f3f3');
  
  // 좌석 데이터: 테이블 2~5, 각 10석
  var seats = [];
  var tables = [2, 3, 4, 5];
  
  for (var t = 0; t < tables.length; t++) {
    var tableNum = tables[t];
    for (var s = 1; s <= 10; s++) {
      seats.push([
        tableNum + '-' + s,   // 좌석번호
        String(tableNum),      // 열구분 (테이블 번호)
        s,                     // 순번
        '공석',                // 상태
        '',                    // 내빈ID
        '',                    // 이름
        '',                    // 소속
        '',                    // 직함
        ''                     // 최종변경시간
      ]);
    }
  }
  
  if (seats.length > 0) {
    sheet.getRange(2, 1, seats.length, seats[0].length).setValues(seats);
  }
  
  // 열 너비 조정
  sheet.setColumnWidth(1, 80);  // 좌석번호
  sheet.setColumnWidth(2, 60);  // 열구분
  sheet.setColumnWidth(3, 50);  // 순번
  sheet.setColumnWidth(4, 60);  // 상태
  sheet.setColumnWidth(5, 80);  // 내빈ID
  sheet.setColumnWidth(6, 80);  // 이름
  sheet.setColumnWidth(7, 200); // 소속
  sheet.setColumnWidth(8, 120); // 직함
  
  Logger.log('좌석세팅 초기화 완료: ' + seats.length + '석');
}

// ── 옵션 시트 업데이트 ───────────────────────────────────
function initOptionSheet(ss) {
  // 기본 시트 (첫 번째 시트)가 옵션 시트인 경우
  var sheets = ss.getSheets();
  var optSheet = null;
  
  // "옵션" 또는 "설정" 시트 찾기, 없으면 첫 번째 시트 사용
  for (var i = 0; i < sheets.length; i++) {
    var name = sheets[i].getName();
    if (name !== '01_내빈명단' && name !== '02_좌석세팅' && name.indexOf('03_') !== 0) {
      optSheet = sheets[i];
      break;
    }
  }
  
  if (optSheet) {
    optSheet.clear();
    optSheet.getRange(1, 1).setValue('열갯수');
    optSheet.getRange(1, 2).setValue(4);
    optSheet.getRange(2, 1).setValue('1열당좌석수');
    optSheet.getRange(2, 2).setValue(10);
    Logger.log('옵션 시트 업데이트 완료');
  }
}
