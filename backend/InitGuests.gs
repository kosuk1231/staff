// ============================================================
// 내빈 의전 시스템 — 내빈 명단 + 좌석세팅 초기화 스크립트
// Apps Script 편집기에서 initializeAllData() 함수를 실행하세요.
// ============================================================

function initializeAllData() {
  var ss = SpreadsheetApp.getActiveSpreadsheet();
  var ui = SpreadsheetApp.getUi();
  
  if (ui.alert(
    '전체 데이터 초기화',
    '내빈명단과 좌석세팅을 새 데이터로 교체합니다.\n기존 데이터는 모두 삭제됩니다.\n계속하시겠습니까?',
    ui.ButtonSet.YES_NO
  ) !== ui.Button.YES) return;
  
  initGuestSheet(ss);
  initSeatSheet(ss);
  initOptionSheet(ss);
  
  ui.alert('초기화 완료', '내빈 40명, 좌석 50석이 설정되었습니다.', ui.ButtonSet.OK);
}

